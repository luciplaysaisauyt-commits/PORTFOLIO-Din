<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DIN – CLM Mafia Platform Case Study</title>

  <link rel="icon" type="image/png" href="/assets/DIN.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@200;300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="/assets/css/clm.css">

  <script src="/assets/js/main.js" defer></script>
</head>

<body>
  <div class="bg-layer"></div>
  <div class="bg-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
  <div class="progress-bar" id="progressBar"></div>

  <div class="page-wrap">
    <%- include("../partials/header") %>

    <%
      const subnavItems = [
        { id: "overview", label: "Overview" },
        { id: "problem", label: "Problem" },
        { id: "before-after", label: "Before/After" },
        { id: "process", label: "Process" },
        { id: "colors", label: "Design System" },
        { id: "uikit", label: "UI Kit" },
        { id: "screens", label: "Screens" },
        { id: "admin", label: "Admin" },
        { id: "learnings", label: "Learnings" }
      ];
    %>

    <%- include("../partials/caseSubnav", { subnavItems }) %>

    <main>
      <div class="case-wrap">

        <div class="hero" data-reveal>
          <div>
            <div class="hero-accent"></div>
            <div class="eyebrow">UI / UX Redesign &nbsp;·&nbsp; Case Study &nbsp;·&nbsp; Real Client Project</div>
            <h1 class="case-title">CLM Mafia<br>Platform</h1>
            <p class="case-sub">Full redesign of a competitive Mafia game platform — ratings, tournaments, clubs, and game tracking. From a cluttered legacy interface to a modern product used by real players.</p>
            <div class="btn-row">
              <a class="btn primary" href="/gallery">← Back to gallery</a>
              <a class="btn" href="/contact">Get in touch</a>
            </div>
            <div class="case-meta" style="margin-top:22px">
              <div class="meta-card"><div class="meta-k">Role</div><div class="meta-v">UI / UX Designer</div></div>
              <div class="meta-card"><div class="meta-k">Tools</div><div class="meta-v"><span class="chip">Figma</span><span class="chip">Adobe Illustrator</span></div></div>
              <div class="meta-card"><div class="meta-k">Type</div><div class="meta-v">Real client project · Full redesign</div></div>
              <div class="meta-card"><div class="meta-k">Deliverables</div><div class="meta-v">20+ screens · UI system · Components</div></div>
            </div>
          </div>
          <div class="hero-img-wrap" data-reveal data-reveal-delay="2">
            <img src="/images/clm/Main page home.webp" alt="CLM Main Page" loading="lazy" decoding="async">
            <div class="hero-overlay"></div>
            <span class="hero-badge">Mafia Platform</span>
          </div>
        </div>

        <div class="case-sections">

          <section class="case-section" id="overview" data-reveal>
            <div class="eyebrow">Project Overview</div>
            <h2 class="case-h2">CLM — the competitive Mafia hub.</h2>
            <p class="case-p">CLM is a real platform for tracking player ratings, running tournaments, managing clubs, and recording game sessions for the board game Mafia. The platform had been running for years on an outdated interface — functional but visually overwhelming and painful to use.</p>
            <p class="case-p" style="margin-top:10px">This was a real paid client project. My goal: redesign the entire product, simplify navigation, establish a strong dark + red visual identity, and build a scalable UI component system. Every screen was designed with the real user in mind — from a first-time visitor to a competitive club owner managing tournaments.</p>
            <div class="stats-grid" style="margin-top:26px">
              <div class="stat" data-reveal data-reveal-delay="1"><div class="stat-n">20+</div><div class="stat-t">Unique screens designed</div></div>
              <div class="stat" data-reveal data-reveal-delay="2"><div class="stat-n">100%</div><div class="stat-t">Custom UI system from scratch</div></div>
              <div class="stat" data-reveal data-reveal-delay="3"><div class="stat-n">Real</div><div class="stat-t">Live client project with real users</div></div>
            </div>
          </section>

          <section class="case-section" id="problem" data-reveal>
            <h2 class="case-h2">Problem and goals</h2>
            <div class="grid2">
              <div class="case-card" data-reveal data-reveal-delay="1">
                <h3>🔴 The Problem</h3>
                <p>The old MafiaRatings site had a cluttered Windows-XP-era layout — dense tables, outdated fonts, no visual hierarchy, complex navigation. New users were lost immediately. Players couldn't find their stats fast. The platform felt untrustworthy for a competitive community.</p>
              </div>
              <div class="case-card" data-reveal data-reveal-delay="2">
                <h3>✅ The Goals</h3>
                <p>Redesign for clarity, speed, and confidence. Create a dark, bold brand identity with red accents. Make ratings, tournaments, and clubs instantly accessible. Build a reusable component library that scales with new features and can be handed off to developers.</p>
              </div>
            </div>
          </section>

          <section class="case-section" id="before-after" data-reveal>
            <div class="eyebrow">Transformation</div>
            <h2 class="case-h2">Before and after.</h2>
            <p class="case-p">The old MafiaRatings interface versus the new CLM redesign — same platform, completely different experience. The old site was built on Windows-era desktop software aesthetics. The new design brings it into 2025.</p>
            <div class="ba-grid">
              <div class="ba-card" data-reveal data-reveal-delay="1">
                <img src="/assets/images/clm/main_pAGE_OLD_MAFIA.webp" alt="Old MafiaRatings interface" loading="lazy" decoding="async">
                <span class="ba-tag before">Before — MafiaRatings</span>
              </div>
              <div class="ba-card" data-reveal data-reveal-delay="2">
                <img src="/images/clm/Main page home.webp" alt="New CLM design" loading="lazy" decoding="async">
                <span class="ba-tag after">After — CLM Redesign</span>
              </div>
            </div>
          </section>

          <section class="case-section" id="process" data-reveal>
            <h2 class="case-h2">Design process</h2>
            <p class="case-p">I followed a structured approach — starting from user flows and information architecture before touching any visual design. Every decision was grounded in real user needs.</p>
            <div class="process-grid">
              <div class="pstep" data-reveal data-reveal-delay="1">
                <div class="pnum">01</div>
                <div class="ptitle">Research & audit</div>
                <div class="pdesc">Analyzed the old platform, identified pain points, mapped all user types: players, club owners, admins, and judges — each with different needs.</div>
              </div>
              <div class="pstep" data-reveal data-reveal-delay="2">
                <div class="pnum">02</div>
                <div class="ptitle">Information architecture</div>
                <div class="pdesc">Restructured navigation and page hierarchy. Defined 7 main sections: Home, Clubs, Tournaments, Ratings, Games, Hall of Fame, Info.</div>
              </div>
              <div class="pstep" data-reveal data-reveal-delay="3">
                <div class="pnum">03</div>
                <div class="ptitle">Design system</div>
                <div class="pdesc">Built color palette, typography scale, and a full component library — cards, tables, badges, buttons, forms — all reusable and consistent.</div>
              </div>
              <div class="pstep" data-reveal data-reveal-delay="4">
                <div class="pnum">04</div>
                <div class="ptitle">Screen design</div>
                <div class="pdesc">Designed all 14+ screens with role-based differences: what a player sees vs a club owner vs an admin. Every state accounted for.</div>
              </div>
            </div>
          </section>

          <section class="case-section" id="colors" data-reveal>
            <h2 class="case-h2">Colors and typography</h2>
            <p class="case-p">A bold dark theme with aggressive red accents — matching the competitive, strategic nature of Mafia. High contrast for readability, strong brand personality for a gaming community.</p>
            <div class="swatch-row" style="margin-top:20px">
              <div class="sw" style="--c:#1a1a1a"><span>Base</span><b>#1A1A1A</b></div>
              <div class="sw" style="--c:#ff3c3c"><span>Accent Red</span><b>#FF3C3C</b></div>
              <div class="sw" style="--c:#222226"><span>Surface</span><b>#222226</b></div>
              <div class="sw" style="--c:#2d2d2d"><span>Card</span><b>#2D2D2D</b></div>
              <div class="sw" style="--c:#ffffff"><span>Text</span><b>#FFFFFF</b></div>
            </div>
            <div class="type-row">
              <div class="type-card">
                <div class="type-k">Display / Headings</div>
                <div class="type-s" style="font-family:'Space Mono',monospace;letter-spacing:.04em">Druk Wide Bold</div>
                <div class="type-ex">CLM Platform</div>
              </div>
              <div class="type-card">
                <div class="type-k">UI / Body text</div>
                <div class="type-s">Inter</div>
                <div class="type-ex" style="font-family:'DM Sans',sans-serif;font-size:22px">Ratings & Tournaments</div>
              </div>
            </div>
          </section>

          <section class="case-section" id="uikit" data-reveal>
            <div class="eyebrow">Component Library</div>
            <h2 class="case-h2">UI Kit.</h2>
            <p class="case-p">A complete, reusable component system built from scratch — buttons, cards, tables, badges, form elements, navigation patterns, and data displays. Every component designed for dark backgrounds with the platform's red accent palette. Handed off with full Figma documentation.</p>
            <div class="screens-grid" style="margin-top:20px">
              <div class="screen-card full" data-reveal data-reveal-delay="1">
                <span class="screen-tag">UI Kit — Full System Overview</span>
                <img src="/images/clm/UI KIT.webp" alt="CLM UI Kit" loading="lazy" decoding="async">
              </div>
              <div class="screen-card" data-reveal data-reveal-delay="1">
                <span class="screen-tag">Player Profile</span>
                <img src="/images/clm/Player.webp" alt="Player Profile" loading="lazy" decoding="async">
              </div>
              <div class="screen-card" data-reveal data-reveal-delay="2">
                <span class="screen-tag">Ratings — Alternative View</span>
                <img src="/images/clm/RAtings.webp" alt="Ratings Alternative" loading="lazy" decoding="async">
              </div>
            </div>
          </section>

          <section class="case-section" id="screens" data-reveal>
            <div class="eyebrow">Full Platform Design</div>
            <h2 class="case-h2">All screens.</h2>
            <p class="case-p">Every page of the platform redesigned — from the homepage with live rankings to individual club profiles, tournament listings, game tracking, player profiles, and the Hall of Fame.</p>

            <div class="screens-grid" style="margin-top:20px">
              <div class="screen-card full" data-reveal data-reveal-delay="1">
                <span class="screen-tag">Homepage — Rankings & Tournaments</span>
                <img src="/images/clm/Main page home.webp" alt="CLM Homepage" loading="lazy" decoding="async">
              </div>

              <div class="screen-card" data-reveal data-reveal-delay="1">
                <span class="screen-tag">Global Ratings Page</span>
                <img src="/images/clm/RATING.webp" alt="Ratings" loading="lazy" decoding="async">
              </div>
              <div class="screen-card" data-reveal data-reveal-delay="2">
                <span class="screen-tag">Clubs List</span>
                <img src="/images/clm/Clubs.webp" alt="Clubs List" loading="lazy" decoding="async">
              </div>

              <div class="screen-card" data-reveal data-reveal-delay="1">
                <span class="screen-tag">Club Page — Visitor View</span>
                <img src="/images/clm/Clubs for Player Owner of club-2.webp" alt="Club Visitor" loading="lazy" decoding="async">
              </div>
              <div class="screen-card" data-reveal data-reveal-delay="2">
                <span class="screen-tag">Club Page — Member View</span>
                <img src="/images/clm/Clubs for Player Owner of club.webp" alt="Club Member" loading="lazy" decoding="async">
              </div>

              <div class="screen-card" data-reveal data-reveal-delay="1">
                <span class="screen-tag">Player Profile — With Club</span>
                <img src="/images/clm/Clubs for Player Owner of club-1.webp" alt="Player Profile" loading="lazy" decoding="async">
              </div>
              <div class="screen-card" data-reveal data-reveal-delay="2">
                <span class="screen-tag">Tournaments — Version 1</span>
                <img src="/images/clm/Tournament 1 version.webp" alt="Tournaments V1" loading="lazy" decoding="async">
              </div>

              <div class="screen-card" data-reveal data-reveal-delay="1">
                <span class="screen-tag">Tournaments — Version 2</span>
                <img src="/images/clm/Tournament 2 version.webp" alt="Tournaments V2" loading="lazy" decoding="async">
              </div>
              <div class="screen-card" data-reveal data-reveal-delay="2">
                <span class="screen-tag">Start Game</span>
                <img src="/assets/images/clm/Start_game.webp" alt="Start Game" loading="lazy" decoding="async">
              </div>

              <div class="screen-card" data-reveal data-reveal-delay="1">
                <span class="screen-tag">Hall of Fame</span>
                <img src="/images/clm/Зал славвы.webp" alt="Hall of Fame" loading="lazy" decoding="async">
              </div>
              <div class="screen-card" data-reveal data-reveal-delay="2">
                <span class="screen-tag">Hall of Fame — Roman Slavi Edition</span>
                <img src="/images/clm/Зал Славы(Rom slavi).webp" alt="Hall of Fame Alt" loading="lazy" decoding="async">
              </div>

              <div class="screen-card" data-reveal data-reveal-delay="1">
                <span class="screen-tag">Player Questionnaire / Profile</span>
                <img src="/images/clm/Анкета.webp" alt="Player Profile" loading="lazy" decoding="async">
              </div>
              <div class="screen-card" data-reveal data-reveal-delay="2">
                <span class="screen-tag">Live Game Interface</span>
                <img src="/images/clm/Frame.webp" alt="Game Interface" loading="lazy" decoding="async">
              </div>

              <div class="screen-card full" data-reveal data-reveal-delay="1">
                <span class="screen-tag">OBS Studio Integration</span>
                <img src="/images/clm/OBS.webp" alt="OBS Integration" loading="lazy" decoding="async">
              </div>

              <div class="screen-card full" data-reveal data-reveal-delay="1">
                <span class="screen-tag">Rules & Platform Information</span>
                <img src="/images/clm/Rules and etc.webp" alt="Rules" loading="lazy" decoding="async">
              </div>
            </div>
          </section>

          <section class="case-section" id="admin" data-reveal>
            <div class="eyebrow">Role-Based Design</div>
            <h2 class="case-h2">Admin panel.</h2>
            <p class="case-p">The platform serves multiple user roles — players, judges, club owners, and admins. The admin panel was designed with full user management: role assignment, status control, blocking, and moderation tools. Two design iterations were created and presented to the client.</p>
            <div class="screens-grid" style="margin-top:18px">
              <div class="screen-card full" data-reveal data-reveal-delay="1">
                <span class="screen-tag">Admin — User Management (Final)</span>
                <img src="/images/clm/Admin.webp" alt="Admin Panel Final" loading="lazy" decoding="async">
              </div>
              <div class="screen-card full" data-reveal data-reveal-delay="2">
                <span class="screen-tag">old mafia website — Legacy Reference</span>
                <img src="/images/clm/old mafia website.webp" alt="Old Mafia Website" loading="lazy" decoding="async">
              </div>
            </div>
          </section>

          <section class="case-section" id="learnings" data-reveal>
            <div class="eyebrow">Key Learnings</div>
            <h2 class="case-h2">What I learned.</h2>
            <div class="learn-grid">
              <div class="learn-card" data-reveal data-reveal-delay="1">
                <div class="learn-n">01</div>
                <div class="learn-t">Role-based design is complex</div>
                <div class="learn-p">Each user type — player, owner, admin, judge — sees and does different things. Good IA planning before visual work is non-negotiable on real platforms.</div>
              </div>
              <div class="learn-card" data-reveal data-reveal-delay="2">
                <div class="learn-n">02</div>
                <div class="learn-t">Data-heavy UIs need hierarchy</div>
                <div class="learn-p">Ratings tables, stats, and game histories carry a lot of data. The design job is making that data readable at a glance — not just making it look good.</div>
              </div>
              <div class="learn-card" data-reveal data-reveal-delay="3">
                <div class="learn-n">03</div>
                <div class="learn-t">Brand identity drives trust</div>
                <div class="learn-p">A consistent dark + red visual language makes the platform feel professional and competitive. Players take it seriously when it looks serious.</div>
              </div>
              <div class="learn-card" data-reveal data-reveal-delay="4">
                <div class="learn-n">04</div>
                <div class="learn-t">Systems scale, one-offs don't</div>
                <div class="learn-p">A proper component library from the start saved enormous time at screen 10, 12, and 14. Consistency came automatically, not by accident.</div>
              </div>
            </div>

            <div class="cta-banner" data-reveal style="margin-top:32px">
              <h3>Let's build something great together.</h3>
              <p>I design clean, purposeful digital products for real clients. If you have a project — let's talk.</p>
              <div class="btn-row">
                <a class="btn primary" href="/contact">Get in touch</a>
                <a class="btn" href="/gallery">All projects</a>
              </div>
            </div>
          </section>

        </div>
      </div>
    </div>
  </main>

  <%- include("../partials/caseFooter", { nav, caseName: "CLM Mafia Platform", theme: "clm" }) %>

<!-- LIGHTBOX -->
<div class="img-modal" id="imgModal" aria-hidden="true">
  <div class="img-modal-backdrop" data-close></div>
  <div class="img-modal-card" role="dialog" aria-modal="true">
    <button class="img-modal-close" type="button" data-close>✕</button>
    <img id="imgModalSrc" src="" alt="Preview">
  </div>
</div>

<script>
  /* SCROLL PROGRESS */
  const progressBar = document.getElementById('progressBar');
  if (progressBar) {
    window.addEventListener('scroll', () => {
      const total = document.documentElement.scrollHeight - window.innerHeight;
      progressBar.style.width = (window.scrollY / total * 100) + '%';
    }, { passive: true });
  }

  /* SCROLL REVEAL */
  const revObs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); revObs.unobserve(e.target); } });
  }, { threshold: 0.07 });
  document.querySelectorAll('[data-reveal]').forEach(el => revObs.observe(el));

  /* SUBNAV ACTIVE */
  const subnavLinks = document.querySelectorAll('.case-subnav-pill a');
  const secObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const id = e.target.id;
      subnavLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + id));
    });
  }, { threshold: 0.22 });
  document.querySelectorAll('.case-section[id]').forEach(s => secObs.observe(s));

  /* LIGHTBOX */
  const modal = document.getElementById('imgModal');
  const modalImg = document.getElementById('imgModalSrc');

  function openModal(src) {
    modalImg.src = src;
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('no-scroll');
  }

  /* Auto-bind all screen/ba/hero images */
  document.querySelectorAll('.screen-card img, .ba-card img, .hero-img-wrap img, .uikit-img img').forEach(img => {
    img.style.cursor = 'zoom-in';
    img.addEventListener('click', () => openModal(img.src));
  });

  modal.querySelectorAll('[data-close]').forEach(el => el.addEventListener('click', () => {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('no-scroll');
  }));

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      modal.classList.remove('open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('no-scroll');
    }
  });
</script>
</body>
</html>